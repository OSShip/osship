# Database
POSTGRES_USER=osship
POSTGRES_PASSWORD=osship_secret
POSTGRES_DB=osship
DATABASE_URL_GENERAL=postgres://osship:osship_secret@postgres:5432/osship?sslmode=disable&search_path=general
DATABASE_URL_PAYMENTS=postgres://osship:osship_secret@postgres:5432/osship?sslmode=disable&search_path=payments
DATABASE_URL_METRICS=postgres://osship:osship_secret@postgres:5432/osship?sslmode=disable&search_path=metrics

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRY_HOURS=24
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost/api/v1/auth/oauth/github/callback
OAUTH_SUCCESS_REDIRECT=http://localhost/auth/github/callback
GITHUB_TOKEN=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=
PLATFORM_FEE_PERCENT=10

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@osship.local

# Jitsi
JITSI_BASE_URL=https://meet.jit.si
JITSI_APP_ID=
JITSI_API_KEY=
JITSI_PRIVATE_KEY_PATH=

# Kafka
KAFKA_BROKERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379

# Service URLs (internal)
AUTH_SERVICE_URL=http://auth:8081
LISTINGS_SERVICE_URL=http://listings:8082
USERS_SERVICE_URL=http://users:8083
SESSIONS_SERVICE_URL=http://sessions:8084
MENTORS_SERVICE_URL=http://mentors:8085
NOTIFICATIONS_SERVICE_URL=http://notifications:8086
PAYMENTS_SERVICE_URL=http://payments:8087
METRICS_SERVICE_URL=http://metrics:8088

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=15d

# Sentry (empty = disabled)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_LOG_LEVEL=info
# Per-service access logs (default: logs/<service>-http-requests.log)
HTTP_REQUEST_LOG_FILE=
NEXT_PUBLIC_SENTRY_DSN=
RUST_LOG=info

# Rate limiting
RATE_LIMIT_AUTH_LOGIN=10
RATE_LIMIT_PAYMENTS_CHECKOUT=5

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api/v1
APP_BASE_URL=http://localhost
